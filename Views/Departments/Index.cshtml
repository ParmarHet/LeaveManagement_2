@model List<LeavePro.Models.Department>
@{
    ViewData["Title"] = "Organizational Hierarchy";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var topLevel = Model.Where(d => d.ParentDepartmentId == null).ToList();
}

<div class="content-header mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h4 class="fw-bold text-dark mb-1">
                <i class="fa-solid fa-sitemap me-2 text-success opacity-75"></i>Organizational Structure
            </h4>
            <p class="text-muted small mb-0">Define and manage your company departments and reporting lines.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm" style="background-color: #86efac; border: none; color: #064e3b; font-weight: 700;">
            <i class="fa-solid fa-plus me-1"></i> New Department
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm text-center py-5 rounded-4">
        <div class="card-body">
            <div class="mb-4">
                <i class="fa-solid fa-folder-open display-1 text-light opacity-50"></i>
            </div>
            <h5 class="fw-bold">No Departments Defined</h5>
            <p class="text-muted mx-auto" style="max-width: 400px;">Build your organizational structure by creating your first department.</p>
            <a asp-action="Create" class="btn btn-outline-success mt-2 rounded-pill px-4">Initialize Setup</a>
        </div>
    </div>
}
else
{
    <div class="row">
        <div class="col-12">
            <div class="tree-container p-4 bg-white rounded-4 border shadow-sm">
                @foreach (var dept in topLevel)
                {
                    @await Html.PartialAsync("_DepartmentNode", dept)
                }
            </div>
        </div>
    </div>
}

<style>
    .tree-container {
        border-color: #f0fdf4 !important;
        background: linear-gradient(to bottom right, #ffffff, #fcfdfc);
    }
    .btn-primary:hover {
        background-color: #6ee7b7 !important;
        transform: translateY(-1px);
    }
    .text-success { color: #059669 !important; }
</style>
