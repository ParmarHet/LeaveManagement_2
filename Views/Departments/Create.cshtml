@model LMS.Models.Department
@{
    ViewData["Title"] = "Create Department";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var allDepts = ViewBag.Departments as List<LMS.Models.Department>;
}

<div class="content-header mb-4">
    <div class="d-flex align-items-center">
        <a asp-action="Index" class="btn btn-light rounded-circle me-3 shadow-sm" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
            <i class="fa-solid fa-arrow-left text-muted"></i>
        </a>
        <div>
            <h4 class="fw-bold text-dark mb-1">New Department</h4>
            <p class="text-muted small mb-0">Establish a new unit in your organizational hierarchy.</p>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-7 mx-auto">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-header border-0 bg-white pt-4 px-4 pb-0">
                <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-folder-plus me-2 text-success opacity-75"></i>Department Details</h6>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-12">
                            <label asp-for="Name" class="form-label small fw-bold text-muted">Department Name <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control border-light bg-light rounded-3 py-2 px-3" placeholder="e.g. Sales & Marketing" required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label small fw-bold text-muted">Brief Description</label>
                            <textarea asp-for="Description" class="form-control border-light bg-light rounded-3 py-2 px-3" rows="3" placeholder="What does this department do?"></textarea>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="ParentDepartmentId" class="form-label small fw-bold text-muted">Reporting Structure</label>
                            <select asp-for="ParentDepartmentId" class="form-select border-light bg-light rounded-3 py-2 px-3">
                                <option value="">— None (This will be a Top-Level Department) —</option>
                                @if (allDepts != null)
                                {
                                    @foreach (var d in allDepts.Where(x => x.ParentDepartmentId == null).OrderBy(x => x.Name))
                                    {
                                        <option value="@d.Id">@d.Name</option>
                                    }
                                }
                            </select>
                            <div class="form-text small text-muted mt-2"><i class="fa-solid fa-circle-info me-1 opacity-50"></i>Sub-departments inherit certain policies and visibility from parents.</div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4 pt-2">
                        <button type="submit" class="btn px-4 fw-bold" style="background-color: #86efac; color: #064e3b; border: none;">
                            <i class="fa-solid fa-check-circle me-1"></i> Register Department
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">See Hierarchy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
