@model LMS.Models.Department
@{
    ViewData["Title"] = "Assign Dept Manager";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var managers = ViewBag.Managers as List<LMS.Models.ApplicationUser> ?? new();
}

<div class="content-header mb-4">
    <div class="d-flex align-items-center">
        <a asp-action="Index" class="btn btn-light rounded-circle me-3 shadow-sm" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
            <i class="fa-solid fa-arrow-left text-muted"></i>
        </a>
        <div>
            <h4 class="fw-bold text-dark mb-1">Assign Manager</h4>
            <p class="text-muted small mb-0">Select a leader for the <span class="text-success fw-bold">@Model.Name</span> department.</p>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-5 col-md-8 mx-auto">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-header border-0 bg-white pt-4 px-4 pb-2">
                <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-user-tie me-2 text-success opacity-75"></i>Relationship Details</h6>
            </div>
            <div class="card-body p-4">
                <form asp-action="AssignManager" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted">Select Active Manager</label>
                        @if (!managers.Any())
                        {
                            <div class="alert alert-warning border-0 rounded-3 small">
                                <i class="fa-solid fa-triangle-exclamation me-2"></i>
                                No active managers found in the system.
                            </div>
                        }
                        else
                        {
                            <select name="managerId" class="form-select border-light bg-light rounded-3 py-2 px-3">
                                <option value="">— Unassign / No Manager —</option>
                                @foreach (var m in managers)
                                {
                                    <option value="@m.Id" selected="@(Model.ManagerId == m.Id)">
                                        @m.FirstName @m.LastName (@m.Email)
                                    </option>
                                }
                            </select>
                        }
                    </div>

                    <div class="d-flex gap-2 pt-2">
                        <button type="submit" class="btn flex-grow-1 py-2 fw-bold" style="background-color: #86efac; color: #064e3b; border: none;" @(!managers.Any() ? "disabled" : "")>
                            <i class="fa-solid fa-check-circle me-1"></i> Update Assignment
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
