@model LMS.Models.EmployeeDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = User.IsInRole("Admin") ? "_AdminLayout" : (User.IsInRole("Manager") ? "_ManagerLayout" : "_EmployeeLayout");
}

<div class="ds-page-header align-items-center">
    <h1 class="ds-page-title">Personal<br>Dashboard</h1>
    
    <div class="d-flex gap-4">
        <!-- Pending Card -->
        <div class="ds-stat-card ds-card-warm-green">
            <div class="ds-stat-label">Pending Requests</div>
            <div class="ds-stat-value">@Model.PendingRequests</div>
            <div class="ds-stat-icon-floating"><i class="bi bi-clock"></i></div>
        </div>

        <!-- Approved Card -->
        <div class="ds-stat-card ds-card-palette-2">
            <div class="ds-stat-label">Approved (Year)</div>
            <div class="ds-stat-value">@Model.ApprovedThisYear</div>
            <div class="ds-stat-icon-floating"><i class="bi bi-check-circle"></i></div>
        </div>

        <!-- Holidays Remaining Card -->
        @{
            var holi = Model.LeaveBalances.FirstOrDefault(b => b.LeaveTypeName.Contains("Holiday", StringComparison.OrdinalIgnoreCase) || b.LeaveTypeCode == "HO");
        }
        @if (holi != null)
        {
            <div class="ds-stat-card ds-card-palette-3">
                <div class="ds-stat-label">@holi.LeaveTypeName Remaining</div>
                <div class="ds-stat-value">@holi.Remaining <span class="fs-6 opacity-75 font-monospace">/ @holi.Allocated</span></div>
                <div class="ds-stat-icon-floating"><i class="bi bi-calendar3"></i></div>
            </div>
        }
        else if (Model.LeaveBalances.Any())
        {
            var firstBalance = Model.LeaveBalances.First();
            <div class="ds-stat-card ds-card-palette-3">
                <div class="ds-stat-label">@firstBalance.LeaveTypeName Remaining</div>
                <div class="ds-stat-value">@firstBalance.Remaining <span class="fs-6 opacity-75 font-monospace">/ @firstBalance.Allocated</span></div>
                <div class="ds-stat-icon-floating"><i class="bi bi-wallet2"></i></div>
            </div>
        }
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="ds-filter-bar mb-3">
            <select id="statusFilter" class="form-select w-auto rounded-pill border-light text-muted small" onchange="filterLeaveHistory()">
                <option value="All">All Status</option>
                <option value="Approved">Approved</option>
                <option value="Pending">Pending</option>
                <option value="Rejected">Rejected</option>
                <option value="Cancelled">Cancelled</option>
            </select>
        </div>
        
        <div class="ds-table-container mt-0">
            <div class="px-3 py-2 border-bottom d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0">Recent Leave Requests</h6>
                <a asp-action="History" class="small text-decoration-none">View All</a>
            </div>
            @if (!Model.RecentLeaves.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-inbox fs-1 d-block mb-2 opacity-25"></i>
                    <p class="small mb-0">No leave requests yet. <a asp-action="Apply">Apply now →</a></p>
                </div>
            }
            else
            {
                <table class="ds-table" id="leaveHistoryTable">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>From</th>
                            <th>To</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var l in Model.RecentLeaves)
                    {
                        var status = l.Cancelled ? "Cancelled" : (l.Approved == null ? "Pending" : (l.Approved == true ? "Approved" : "Rejected"));
                        <tr data-status="@status">
                            <td><span class="fw-bold">@l.LeaveType?.Name</span></td>
                            <td>@l.StartDate.ToString("dd MMM yyyy")</td>
                            <td>@l.EndDate.ToString("dd MMM yyyy")</td>
                            <td>
                                @if (status == "Cancelled") { <div class="ds-status-dot" style="background:#6b7280" title="Cancelled">C</div> }
                                else if (status == "Pending") { <div class="ds-status-dot ds-dot-pending" title="Pending">P</div> }
                                else if (status == "Approved") { <div class="ds-status-dot ds-dot-success" title="Approved">A</div> }
                                else { <div class="ds-status-dot ds-dot-cancel" title="Rejected">R</div> }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </div>
    </div>
    <div class="col-lg-4">
        <div class="ds-table-container mt-0 p-4">
            <h6 class="fw-bold mb-4">Leave Balance Summary</h6>
            @{
                var filteredBalances = Model.LeaveBalances.Where(b => 
                    (b.LeaveTypeCode != "CO" && b.LeaveTypeCode != "LW" && b.LeaveTypeCode != "ML" && b.LeaveTypeCode != "BL") || 
                    b.Used > 0 || b.Allocated > 0).ToList();
            }
            @foreach (var b in filteredBalances)
            {
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="fw-semibold small">@b.LeaveTypeName</span>
                        <span class="small text-muted">@b.Remaining / @b.Allocated days</span>
                    </div>
                    <div class="progress" style="height:10px; border-radius: 5px; background: #f3f4f6;">
                        <div class="progress-bar" style="width:@(b.Allocated > 0 ? (b.Used * 100 / b.Allocated) : 0)%; background:#2563eb; border-radius: 5px;"></div>
                    </div>
                </div>
            }
            @if (!filteredBalances.Any())
            {
                <p class="text-muted small text-center py-4">No active leave allocations found.</p>
            }
        </div>
    </div>
</div>

<script>
    function filterLeaveHistory() {
        const filterStatus = document.getElementById('statusFilter').value;
        const rows = document.querySelectorAll('#leaveHistoryTable tbody tr');

        rows.forEach(row => {
            if (filterStatus === 'All' || row.dataset.status === filterStatus) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }
</script>
