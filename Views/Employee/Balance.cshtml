@model IEnumerable<LeavePro.Models.LeaveBalanceViewModel>
@{
    ViewData["Title"] = "Leave Balance";
    Layout = User.IsInRole("Admin") ? "_AdminLayout" : (User.IsInRole("Manager") ? "_ManagerLayout" : "_EmployeeLayout");

    // Leave categories logic:
    // 1. Annual Allocations (Standard): PL, SL, CL always show.
    // 2. Credits: CO shows only if balance exists.
    // 3. Special/Unallocated Usage: BL, ML, LW, or CO (with 0 balance but used) show only if used > 0.
    
    var activeBalances = Model.Where(b => 
        (b.LeaveTypeCode.Equals("PL", StringComparison.OrdinalIgnoreCase) || 
         b.LeaveTypeCode.Equals("SL", StringComparison.OrdinalIgnoreCase) || 
         b.LeaveTypeCode.Equals("CL", StringComparison.OrdinalIgnoreCase) ||
         b.LeaveTypeCode.Equals("FD", StringComparison.OrdinalIgnoreCase) ||
         b.LeaveTypeName.Contains("Casual", StringComparison.OrdinalIgnoreCase) ||
         b.LeaveTypeName.Contains("Floating", StringComparison.OrdinalIgnoreCase)) ||
        (b.LeaveTypeCode.Equals("CO", StringComparison.OrdinalIgnoreCase) && b.Allocated > 0)
    ).ToList();

    var usageHistory = Model.Where(b => 
        ((b.LeaveTypeCode == "BL" || b.LeaveTypeCode == "ML" || b.LeaveTypeCode == "LW") && b.Used > 0) ||
        (b.LeaveTypeCode == "CO" && b.Allocated == 0 && b.Used > 0)
    ).ToList();

    var totalAllocated = activeBalances.Sum(b => b.Allocated);
    var totalUsed      = activeBalances.Sum(b => b.Used);
    var totalRemaining = activeBalances.Sum(b => b.Remaining);
}

@section Styles {
<style>

    :root {
        --lms-navy:       #0f1e35;
        --lms-blue:       #1d4ed8;
        --lms-blue-mid:   #3b82f6;
        --lms-surface:    #f8fafc;
        --lms-surface-2:  #f1f5f9;
        --lms-border:     #e2e8f0;
        --lms-muted:      #64748b;
        --lms-text:       #0f172a;
        --lms-white:      #ffffff;

        /* Status palette */
        --s-green-bar: var(--ds-palette-3);
 
        --s-amber-bg:  var(--ds-palette-5);
        --s-amber-mid: var(--ds-palette-4);
        --s-amber-txt: var(--ds-palette-1);
        --s-amber-bar: var(--ds-palette-3);
 
        --s-red-bg:    #fff1f2;
        --s-red-mid:   #fecdd3;
        --s-red-txt:   #be123c;
        --s-red-bar:   #f43f5e;
 
        --s-open-bg:   #eff6ff;
        --s-open-txt:  #1d4ed8;
        --s-open-bar:  #93c5fd;
    }

    /* ── Base typography ───────────────────────────── */
    .lb-page {
        font-family: 'DM Sans', sans-serif;
        color: var(--lms-text);
    }

    /* ── Page header ───────────────────────────────── */
    .lb-page-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 28px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .lb-page-title {
        font-family: 'Sora', sans-serif;
        font-size: 24px;
        font-weight: 700;
        color: var(--lms-navy);
        letter-spacing: -0.5px;
        margin: 0;
        line-height: 1.2;
    }

    .lb-page-subtitle {
        font-size: 13px;
        color: var(--lms-muted);
        margin: 4px 0 0;
        font-weight: 400;
    }

    .lb-fy-badge {
        font-family: 'DM Sans', sans-serif;
        font-size: 12px;
        font-weight: 500;
        color: var(--lms-blue);
        background: #dbeafe;
        border: 1px solid #bfdbfe;
        padding: 5px 14px;
        border-radius: 20px;
        letter-spacing: 0.2px;
        white-space: nowrap;
    }

    /* ── Summary strip ─────────────────────────────── */
    .lb-summary {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 32px;
    }

    .lb-summary-card {
        background: var(--lms-white);
        border: 1px solid var(--lms-border);
        border-radius: 14px;
        padding: 20px 22px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: box-shadow 0.2s;
    }

    .lb-summary-card:hover {
        box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    }

    .lb-summary-icon {
        width: 42px;
        height: 42px;
        border-radius: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 17px;
        flex-shrink: 0;
    }

    .si-blue   { background: #dbeafe; }
    .si-amber  { background: #fef3c7; }
    .si-green  { background: #dcfce7; }

    .lb-summary-label {
        font-size: 12px;
        font-weight: 500;
        color: var(--lms-muted);
        letter-spacing: 0.3px;
        text-transform: uppercase;
        margin-bottom: 3px;
    }

    .lb-summary-num {
        font-family: 'Sora', sans-serif;
        font-size: 22px;
        font-weight: 700;
        color: var(--lms-navy);
        line-height: 1;
    }

    .lb-summary-unit {
        font-size: 12px;
        color: var(--lms-muted);
        font-weight: 400;
        margin-left: 3px;
    }

    /* ── Section label ─────────────────────────────── */
    .lb-section-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        color: var(--lms-muted);
        margin-bottom: 16px;
        padding-bottom: 10px;
        border-bottom: 1px solid var(--lms-border);
    }

    /* ── Leave cards grid ──────────────────────────── */
    .lb-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 20px;
    }

    /* Card entry animation */
    @@keyframes lb-fadein {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .lb-card {
        background: var(--lms-white);
        border: 1px solid var(--lms-border);
        border-radius: 16px;
        overflow: hidden;
        position: relative;
        transition: box-shadow 0.25s, transform 0.2s, border-color 0.2s;
        animation: lb-fadein 0.35s ease both;
    }

    .lb-card:hover {
        box-shadow: 0 8px 28px rgba(15,30,53,0.09);
        transform: translateY(-2px);
        border-color: #cbd5e1;
    }

    /* Left accent bar — colored by status */
    .lb-card-accent {
        position: absolute;
        top: 0;
        left: 0;
        width: 4px;
        height: 100%;
        border-radius: 0;
    }

    .lb-card-inner {
        padding: 22px 22px 20px 26px;
    }

    /* Card top row */
    .lb-card-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 16px;
    }

    .lb-card-name {
        font-family: 'Sora', sans-serif;
        font-size: 15px;
        font-weight: 600;
        color: var(--lms-navy);
        line-height: 1.3;
        margin: 0;
    }

    .lb-status-chip {
        font-family: 'DM Sans', sans-serif;
        font-size: 11px;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
        white-space: nowrap;
        letter-spacing: 0.2px;
        flex-shrink: 0;
    }

    /* Card numbers */
    .lb-numbers {
        display: flex;
        align-items: baseline;
        gap: 6px;
        margin-bottom: 14px;
    }

    .lb-big-num {
        font-family: 'Sora', sans-serif;
        font-size: 36px;
        font-weight: 700;
        line-height: 1;
        color: var(--lms-navy);
    }

    .lb-num-of {
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        color: var(--lms-muted);
        font-weight: 400;
    }

    /* Progress bar */
    .lb-bar-wrap {
        height: 6px;
        background: var(--lms-surface-2);
        border-radius: 99px;
        overflow: hidden;
        margin-bottom: 12px;
    }

    .lb-bar-fill {
        height: 100%;
        border-radius: 99px;
        transition: width 0.6s ease;
    }

    /* Card footer */
    .lb-card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 12px;
        border-top: 1px solid var(--lms-surface-2);
    }

    .lb-foot-stat {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: var(--lms-muted);
    }

    .lb-foot-stat i {
        font-size: 11px;
    }

    .lb-foot-stat strong {
        font-weight: 600;
        color: #374151;
    }

    .lb-foot-pct {
        font-family: 'Sora', sans-serif;
        font-size: 12px;
        font-weight: 600;
        color: var(--lms-muted);
    }

    /* Open / unlimited card variant */
    .lb-open-info {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        color: var(--lms-muted);
        background: var(--lms-surface);
        border: 1px solid var(--lms-border);
        border-radius: 8px;
        padding: 9px 12px;
        margin-top: 4px;
    }

    .lb-open-info i { color: var(--lms-blue-mid); }

    /* Open card used count */
    .lb-open-used {
        margin-bottom: 12px;
    }

    /* ── Empty state ────────────────────────────────── */
    .lb-empty {
        background: var(--lms-surface);
        border: 1px dashed var(--lms-border);
        border-radius: 16px;
        padding: 60px 24px;
        text-align: center;
    }

    .lb-empty-icon {
        width: 56px;
        height: 56px;
        background: var(--lms-white);
        border: 1px solid var(--lms-border);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        margin: 0 auto 18px;
        color: var(--lms-muted);
    }

    .lb-empty-title {
        font-family: 'Sora', sans-serif;
        font-size: 17px;
        font-weight: 600;
        color: var(--lms-navy);
        margin-bottom: 6px;
    }

    .lb-empty-sub {
        font-size: 13px;
        color: var(--lms-muted);
        margin: 0;
    }

    /* ── Responsive ─────────────────────────────────── */
    @@media (max-width: 768px) {
        .lb-summary { grid-template-columns: 1fr; }
        .lb-grid    { grid-template-columns: 1fr; }
        .lb-page-header { align-items: flex-start; flex-direction: column; }
    }

    @@media (max-width: 480px) {
        .lb-big-num { font-size: 28px; }
    }
</style>
}

<div class="lb-page">

    <!-- ── Page Header ──────────────────────────────── -->
    <div class="lb-page-header">
        <div>
            <h3 class="lb-page-title">Leave Balances</h3>
            <p class="lb-page-subtitle">Your current allocation status across all leave types</p>
        </div>
        <span class="lb-fy-badge">
            <i class="fa-regular fa-calendar me-1"></i> FY @DateTime.Now.Year–@(DateTime.Now.Year + 1)
        </span>
    </div>

    <!-- ── Summary Strip (only if there are standard leaves) ── -->
    @if (activeBalances.Any(b => b.Allocated > 0))
    {
        <div class="lb-summary">
            <div class="lb-summary-card">
                <div class="lb-summary-icon si-blue">
                    <i class="fa-solid fa-layer-group" style="color:#1d4ed8"></i>
                </div>
                <div>
                    <div class="lb-summary-label">Total Allocated</div>
                    <div>
                        <span class="lb-summary-num">@totalAllocated</span>
                        <span class="lb-summary-unit">days</span>
                    </div>
                </div>
            </div>
            <div class="lb-summary-card">
                <div class="lb-summary-icon si-amber">
                    <i class="fa-solid fa-calendar-minus" style="color:#b45309"></i>
                </div>
                <div>
                    <div class="lb-summary-label">Total Used</div>
                    <div>
                        <span class="lb-summary-num">@totalUsed</span>
                        <span class="lb-summary-unit">days</span>
                    </div>
                </div>
            </div>
            <div class="lb-summary-card">
                <div class="lb-summary-icon si-green">
                    <i class="fa-solid fa-circle-check" style="color:#15803d"></i>
                </div>
                <div>
                    <div class="lb-summary-label">Remaining</div>
                    <div>
                        <span class="lb-summary-num">@totalRemaining</span>
                        <span class="lb-summary-unit">days</span>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- ── Annual Allocations Section ──────────────── -->
    @if (activeBalances.Any())
    {
        <div class="lb-section-label">Annual Allocations & Credits</div>
        <div class="lb-grid mb-5">
        @{ int cardIndex = 0; }
        @foreach (var b in activeBalances)
        {
            var total     = b.Allocated;
            var used      = b.Used;
            var remaining = b.Remaining;
            
            var usedPct      = total > 0 ? (int)Math.Round((double)used / total * 100) : 0;
            var remainingPct = 100 - usedPct;

            // Color tokens
            string accentColor, barColor, chipBg, chipColor;

            if (remainingPct > 50) {
                accentColor = "var(--s-green-bar)";
                barColor    = "var(--s-green-bar)";
                chipBg      = "var(--s-green-bg)";
                chipColor   = "var(--s-green-txt)";
            } else if (remainingPct > 20) {
                accentColor = "var(--s-amber-bar)";
                barColor    = "var(--s-amber-bar)";
                chipBg      = "var(--s-amber-bg)";
                chipColor   = "var(--s-amber-txt)";
            } else {
                accentColor = "var(--s-red-bar)";
                barColor    = "var(--s-red-bar)";
                chipBg      = "var(--s-red-bg)";
                chipColor   = "var(--s-red-txt)";
            }

            var delay = cardIndex * 60;
            cardIndex++;
            <div class="lb-card" style="animation-delay: @(delay)ms">
                <div class="lb-card-accent" style="background: @accentColor;"></div>
                <div class="lb-card-inner">
                    <div class="lb-card-top">
                        <p class="lb-card-name">@b.LeaveTypeName</p>
                        <span class="lb-status-chip" style="background:@chipBg; color:@chipColor;">
                            @if (remainingPct > 50) { <i class="fa-solid fa-seedling me-1"></i><span>Good</span> }
                            else if (remainingPct > 20) { <i class="fa-solid fa-triangle-exclamation me-1"></i><span>Low</span> }
                            else { <i class="fa-solid fa-circle-exclamation me-1"></i><span>Critical</span> }
                        </span>
                    </div>

                    <div class="lb-numbers">
                        <span class="lb-big-num">@remaining</span>
                        <span class="lb-num-of">of @total days left</span>
                    </div>

                    <div class="lb-bar-wrap">
                        <div class="lb-bar-fill" style="width: @usedPct%; background: @barColor;"></div>
                    </div>

                    <div class="lb-card-footer">
                        <div class="lb-foot-stat">
                            <i class="fa-solid fa-calendar-xmark" style="color:@barColor;"></i>
                            Used: <strong>@used day@(used == 1 ? "" : "s")</strong>
                        </div>
                        <span class="lb-foot-pct">@usedPct% used</span>
                    </div>
                </div>
            </div>
        }
        </div>
    }

    <!-- ── Usage History Section ───────────────────── -->
    @if (usageHistory.Any())
    {
        <div class="lb-section-label" style="margin-top: 40px;">Usage History (Special Leaves)</div>
        <div class="lb-grid">
        @foreach (var b in usageHistory)
        {
            <div class="lb-card" style="border-style: dashed; background: #fdfdfd;">
                <div class="lb-card-accent" style="background: var(--lms-border);"></div>
                <div class="lb-card-inner">
                    <div class="lb-card-top">
                        <p class="lb-card-name">@b.LeaveTypeName</p>
                        <span class="lb-status-chip" style="background:var(--lms-surface-2); color:var(--lms-muted);">
                            History Only
                        </span>
                    </div>

                    <div class="lb-numbers lb-open-used">
                        <span class="lb-big-num">@b.Used</span>
                        <span class="lb-num-of">day@(b.Used == 1 ? "" : "s") consumed</span>
                    </div>

                    <div class="lb-open-info" style="border-style: dotted;">
                        <i class="fa-solid fa-clock-rotate-left"></i>
                        Recorded usage for the current financial year.
                    </div>
                </div>
            </div>
        }
        </div>
    }

    @if (!activeBalances.Any() && !usageHistory.Any())
    {
        <!-- Empty state -->
        <div class="lb-empty">
            <div class="lb-empty-icon">
                <i class="fa-regular fa-calendar-xmark"></i>
            </div>
            <p class="lb-empty-title">No Leave Allocations Found</p>
            <p class="lb-empty-sub">Your leave balances haven't been configured yet. Please contact HR or your administrator.</p>
        </div>
    }

</div>
