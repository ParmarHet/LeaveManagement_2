@using Microsoft.AspNetCore.Identity
@inject UserManager<LMS.Models.ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LEAVE PRO Manager Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard-theme.css" asp-append-version="true" />
    <!-- Improve typography for manager layout -->
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
    <style>
        /* Make manager sidebar visually match employee/admin (lighter, friendlier) */
        body.dashboard-body.employee-theme .ds-sidebar {
            background: var(--ds-accent-soft); 
            border-right: 1px solid var(--ds-border-light);
        }
        body.dashboard-body.employee-theme .ds-logo-icon {
            background: var(--ds-accent);
            color: #fff;
        }
        body.dashboard-body.employee-theme .ds-nav-link {
            color: #0f172a; 
        }
        body.dashboard-body.employee-theme .ds-nav-link:hover {
            background: #e6f0ff;
            color: var(--ds-accent);
        }
        body.dashboard-body.employee-theme .ds-nav-link.active {
            background: linear-gradient(90deg, var(--ds-accent), #1d4ed8);
            color: #fff;
            box-shadow: 0 6px 20px rgba(29,78,216,0.16);
        }
        .ds-profile-name, .ds-logo-text .brand-name { font-family: 'Sora', sans-serif; }
        .ds-nav-link span, .ds-nav-link i { font-family: 'DM Sans', sans-serif; }
        .ds-page-title { font-family: 'Sora', sans-serif; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="dashboard-body employee-theme">
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isPersonalMode = currentController == "Employee";
    var isTeamMode = !isPersonalMode;
}

<!-- SIDEBAR OVERLAY (mobile) -->
<div class="ds-sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

<!-- SIDEBAR -->
<aside class="ds-sidebar" id="mainSidebar">
    <div class="ds-sidebar-logo">
        <div class="ds-logo-icon">LP</div>
        <div class="ds-logo-text">
            <div class="brand-name">LeavePro Manager</div>
        </div>
    </div>

    <nav class="ds-sidebar-nav">
        @if (isTeamMode)
        {
            <a class="ds-nav-link @(currentAction == "Dashboard" && currentController == "Manager" ? "active" : "")" asp-controller="Manager" asp-action="Dashboard" title="Team Dashboard">
                <i class="bi bi-grid-fill"></i><span>Team Dashboard</span>
            </a>
            <a class="ds-nav-link @(currentAction == "PendingRequests" ? "active" : "")" asp-controller="Manager" asp-action="PendingRequests" title="Approvals">
                <i class="bi bi-check-square-fill"></i><span>Approvals</span>
            </a>
            <a class="ds-nav-link @(currentAction == "History" && currentController == "Manager" ? "active" : "")" asp-controller="Manager" asp-action="History" title="Team History">
                <i class="bi bi-clock-history"></i><span>Team History</span>
            </a>
            <a class="ds-nav-link @(currentAction == "TeamCalendar" ? "active" : "")" asp-controller="Manager" asp-action="TeamCalendar" title="Team Calendar">
                <i class="bi bi-calendar-event"></i><span>Team Calendar</span>
            </a>
            <a class="ds-nav-link @(currentAction == "MyTeam" ? "active" : "")" asp-controller="Manager" asp-action="MyTeam" title="Team Portal">
                <i class="bi bi-person-workspace"></i><span>Team Portal</span>
            </a>
            <a class="ds-nav-link @(currentAction == "Holidays" && currentController == "Manager" ? "active" : "")" asp-controller="Manager" asp-action="Holidays" title="Holidays">
                <i class="bi bi-calendar-heart"></i><span>Holidays</span>
            </a>
        }
        else
        {
            <a class="ds-nav-link @(currentAction == "Dashboard" && currentController == "Employee" ? "active" : "")" href="@Url.Action("Dashboard","Employee")" title="My Dashboard">
                <i class="bi bi-grid-fill"></i><span>My Dashboard</span>
            </a>
            <a class="ds-nav-link @(currentAction == "Apply" ? "active" : "")" href="@Url.Action("Apply","Employee")" title="Apply Leave">
                <i class="bi bi-plus-circle-fill"></i><span>Apply Leave</span>
            </a>
            <a class="ds-nav-link @(currentAction == "History" && currentController == "Employee" ? "active" : "")" href="@Url.Action("History","Employee")" title="My History">
                <i class="bi bi-clock-history"></i><span>My History</span>
            </a>
            <a class="ds-nav-link @(currentAction == "Balance" && currentController == "Employee" ? "active" : "")" href="@Url.Action("Balance","Employee")" title="Leave Balance">
                <i class="bi bi-wallet2"></i><span>Leave Balance</span>
            </a>
            <a class="ds-nav-link @(currentAction == "Holidays" && currentController == "Employee" ? "active" : "")" href="@Url.Action("Holidays","Employee")" title="Holidays">
                <i class="bi bi-calendar-event"></i><span>Holidays</span>
            </a>
            <a class="ds-nav-link @(currentAction == "LeavePolicies" && currentController == "Employee" ? "active" : "")" href="@Url.Action("LeavePolicies","Employee")" title="Leave Policies">
                <i class="bi bi-file-earmark-text"></i><span>Leave Policies</span>
            </a>
        }
    </nav>

    <div class="ds-sidebar-footer">
        <a class="ds-nav-link @(currentAction == "Profile" ? "active" : "")" href="@Url.Action("Profile","Employee")" title="Profile">
            <i class="bi bi-person-circle"></i>
            <span>Profile</span>
        </a>
        <form class="w-100" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="ds-nav-link border-0 bg-transparent w-100" title="Logout">
                <i class="bi bi-box-arrow-right"></i>
                <span>Logout</span>
            </button>
        </form>
    </div>
</aside>

<!-- TOPBAR -->
<div class="ds-topbar">
    <button class="btn btn-link p-0 text-dark fs-4" onclick="toggleSidebar()" title="Toggle Menu">
        <i class="bi bi-list"></i>
    </button>

    <div class="ms-auto d-flex align-items-center gap-4">
        @{
            var u = await UserManager.GetUserAsync(User);
            var fullName = u != null ? $"{u.FirstName} {u.LastName}" : User.Identity?.Name;
        }
        @if (isTeamMode)
        {
            <a class="btn btn-primary btn-sm rounded-pill px-4 fw-bold d-none d-md-flex align-items-center gap-2 shadow-sm" style="background: linear-gradient(135deg, #4f46e5, #3b82f6); border: none;" href="@Url.Action("Dashboard","Employee")">
                <i class="bi bi-person-fill"></i> Personal Mode
            </a>
        }
        else
        {
            <a class="btn btn-success btn-sm rounded-pill px-4 fw-bold d-none d-md-flex align-items-center gap-2 shadow-sm" style="background: linear-gradient(135deg, #10b981, #059669); border: none;" href="@Url.Action("Dashboard","Manager")">
                <i class="bi bi-people-fill"></i> Team Mode
            </a>
        }

        <div class="ds-profile-trigger">
            <div class="text-end d-none d-sm-block">
                <div class="ds-profile-name">@fullName</div>
                <div class="ds-profile-role">Manager</div>
            </div>
            <div class="ds-avatar shadow-sm border ms-2">
                <img src="https://ui-avatars.com/api/?name=@(u?.FirstName ?? "U")&background=16a34a&color=fff" alt="User">
            </div>
        </div>
    </div>
</div>

<!-- MAIN CONTENT -->
<main class="ds-main">
    <div class="container-fluid p-0">
        @RenderBody()
    </div>
</main>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function toggleSidebar() {
        const sidebar = $('#mainSidebar');
        const main = $('.ds-main');
        const topbar = $('.ds-topbar');
        
        sidebar.toggleClass('sidebar-closed');
        main.toggleClass('content-full');
        topbar.toggleClass('content-full');
        
        if ($(window).width() < 992) {
            sidebar.toggleClass('show');
            $('#sidebarOverlay').toggleClass('show');
        }
    }
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
