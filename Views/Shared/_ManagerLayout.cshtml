@using Microsoft.AspNetCore.Identity
@inject UserManager<LMS.Models.ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LEAVE PRO Manager Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard-theme.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="dashboard-body">
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isPersonalMode = currentController == "Employee";
    var isTeamMode = !isPersonalMode;
}

<!-- SIDEBAR OVERLAY (mobile) -->
<div class="ds-sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

<!-- SIDEBAR (Narrow Rail) -->
<aside class="ds-sidebar" id="mainSidebar">
    <div class="ds-sidebar-logo">
        <div class="ds-logo-icon">LP</div>
        <div class="ds-logo-text">
            <div class="brand-name">LEAVE PRO Manager</div>
        </div>
    </div>

    <!-- Mode Toggle (only shown when sidebar expanded or on mobile) -->
    <div class="ds-mode-toggle d-none" id="modeRailToggle">
        <a class="ds-mode-btn @(isTeamMode ? "team-active" : "inactive")" asp-controller="Manager" asp-action="Dashboard" title="Team Mode">
            <i class="bi bi-people-fill"></i>
        </a>
        <a class="ds-mode-btn @(isPersonalMode ? "personal-active" : "inactive")" asp-controller="Employee" asp-action="Dashboard" title="Personal Mode">
            <i class="bi bi-person-fill"></i>
        </a>
    </div>

    <nav class="ds-sidebar-nav">
        @if (isTeamMode)
        {
            <a class="ds-nav-link @(currentAction == "Dashboard" && currentController == "Manager" ? "active" : "")" asp-controller="Manager" asp-action="Dashboard" title="Team Dashboard">
                <i class="bi bi-grid-fill"></i><span>Team Dashboard</span>
            </a>
            <a class="ds-nav-link @(currentAction == "PendingRequests" ? "active" : "")" asp-controller="Manager" asp-action="PendingRequests" title="Approvals">
                <i class="bi bi-check-square-fill"></i><span>Approvals</span>
            </a>
            <a class="ds-nav-link @(currentAction == "History" && currentController == "Manager" ? "active" : "")" asp-controller="Manager" asp-action="History" title="Team History">
                <i class="bi bi-clock-history"></i><span>Team History</span>
            </a>
            <a class="ds-nav-link @(currentAction == "TeamCalendar" ? "active" : "")" asp-controller="Manager" asp-action="TeamCalendar" title="Team Calendar">
                <i class="bi bi-calendar-event"></i><span>Team Calendar</span>
            </a>
            <a class="ds-nav-link @(currentAction == "MyTeam" ? "active" : "")" asp-controller="Manager" asp-action="MyTeam" title="Team Portal">
                <i class="bi bi-person-workspace"></i><span>Team Portal</span>
            </a>
        }
        else
        {
            <a class="ds-nav-link @(currentAction == "Dashboard" && currentController == "Employee" ? "active" : "")" asp-controller="Employee" asp-action="Dashboard" title="My Dashboard">
                <i class="bi bi-grid-fill"></i><span>My Dashboard</span>
            </a>
            <a class="ds-nav-link @(currentAction == "Apply" ? "active" : "")" asp-controller="Employee" asp-action="Apply" title="Apply Leave">
                <i class="bi bi-plus-circle-fill"></i><span>Apply Leave</span>
            </a>
            <a class="ds-nav-link @(currentAction == "History" && currentController == "Employee" ? "active" : "")" asp-controller="Employee" asp-action="History" title="My History">
                <i class="bi bi-clock-history"></i><span>My History</span>
            </a>
        }
        
        <div class="ds-sidebar-divider"></div>
        <a class="ds-nav-link @(currentAction == "Dashboard" && isTeamMode ? "" : "inactive")" asp-controller="Employee" asp-action="Dashboard" title="Switch Mode">
            <i class="bi bi-arrow-left-right"></i><span>Switch Mode</span>
        </a>
    </nav>

    <div class="ds-sidebar-footer">
        <form class="w-100" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="ds-nav-link border-0 bg-transparent w-100" title="Logout">
                <i class="bi bi-box-arrow-right"></i>
                <span>Logout</span>
            </button>
        </form>
    </div>
</aside>

<!-- TOPBAR -->
<div class="ds-topbar">
    @if (isPersonalMode) { <span class="badge rounded-pill bg-primary me-2">Personal Mode</span> }
    else { <span class="badge rounded-pill bg-success me-2">Team Mode</span> }
    
    <div class="ds-profile-trigger">
        <div class="text-end d-none d-sm-block">
            <div class="ds-profile-name">@User.Identity?.Name</div>
            <div class="ds-profile-role">Manager</div>
        </div>
        <div class="ds-avatar">
            <img src="https://ui-avatars.com/api/?name=@(User.Identity?.Name)&background=3b82f6&color=fff" alt="User">
        </div>
    </div>
</div>

<!-- MAIN CONTENT -->
<main class="ds-main">
    <div class="container-fluid p-0">
        @RenderBody()
    </div>
</main>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function toggleSidebar() {
        $('#mainSidebar').toggleClass('show');
        $('#sidebarOverlay').toggleClass('show');
    }
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
