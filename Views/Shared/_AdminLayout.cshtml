@using Microsoft.AspNetCore.Identity
@inject SignInManager<LMS.Models.ApplicationUser> SignInManager
@inject UserManager<LMS.Models.ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LEAVE PRO Admin Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard-theme.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="dashboard-body admin-theme">

<!-- SIDEBAR OVERLAY (mobile) -->
<div class="ds-sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

<!-- SIDEBAR (Narrow Rail) -->
<aside class="ds-sidebar" id="mainSidebar">
    <div class="ds-sidebar-logo">
        <div class="ds-logo-icon">LP</div>
        <div class="ds-logo-text">
            <div class="brand-name">LEAVE PRO Admin</div>
        </div>
    </div>

    <nav class="ds-sidebar-nav">
        <a class="ds-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" && ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")"
           asp-controller="Admin" asp-action="Dashboard" title="Dashboard">
            <i class="bi bi-grid-fill"></i>
            <span>Dashboard</span>
        </a>
        
        <a class="ds-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "LeaveHistory" ? "active" : "")"
           asp-controller="Admin" asp-action="LeaveHistory" title="Leave History">
            <i class="bi bi-clock-history"></i>
            <span>Leave History</span>
        </a>

        <a class="ds-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Departments" ? "active" : "")"
           asp-controller="Departments" asp-action="Index" title="Departments">
            <i class="bi bi-diagram-3-fill"></i>
            <span>Departments</span>
        </a>

        <a class="ds-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "HolidayCalendar" ? "active" : "")"
           asp-controller="Admin" asp-action="HolidayCalendar" title="Holidays">
            <i class="bi bi-calendar-event"></i>
            <span>Holidays</span>
        </a>

        <a class="ds-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")"
           asp-controller="Users" asp-action="Index" title="Users">
            <i class="bi bi-people-fill"></i>
            <span>Users</span>
        </a>

        <a class="ds-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Pending" ? "active" : "")"
           asp-controller="Users" asp-action="Pending" title="Pending">
            <i class="bi bi-person-check-fill"></i>
            <span>Pending</span>
        </a>
    </nav>

    <div class="ds-sidebar-footer">
        <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword" class="ds-nav-link" title="Settings"><i class="bi bi-gear-fill"></i><span>Settings</span></a>
        <form class="w-100" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="ds-nav-link border-0 bg-transparent w-100" title="Logout">
                <i class="bi bi-box-arrow-right"></i>
                <span>Logout</span>
            </button>
        </form>
    </div>
</aside>

<!-- TOPBAR -->
<div class="ds-topbar">
    <div class="d-flex align-items-center w-100 justify-content-end gap-3">
        <!-- Date Display -->
        <div class="text-muted small fw-semibold d-none d-md-flex align-items-center me-2">
            <i class="bi bi-calendar3 me-2"></i> @DateTime.Now.ToString("dddd, dd MMM yyyy")
        </div>

        <!-- Notification Bell -->
        <a asp-controller="Notifications" asp-action="Index" class="position-relative text-dark text-decoration-none" title="Notifications">
            <i class="bi bi-bell-fill fs-5"></i>
            <span id="notification-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65em; display: none;">
                0
            </span>
        </a>

        <!-- Profile Element -->
        <div class="text-end ms-3">
            @{ var u = await UserManager.GetUserAsync(User); }
            <div class="ds-profile-name" style="font-weight: 600;">@(u != null ? $"{u.FirstName} {u.LastName}" : User.Identity?.Name)</div>
            <div class="ds-profile-role" style="font-size: 0.8rem; color: #6c757d;">Admin</div>
        </div>
    </div>
</div>

<!-- MAIN CONTENT -->
<main class="ds-main">
    <div class="container-fluid p-0">
        @RenderBody()
    </div>
</main>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function toggleSidebar() {
        $('#mainSidebar').toggleClass('show');
        $('#sidebarOverlay').toggleClass('show');
    }

    // Fetch notifications dynamically
    $(document).ready(function() {
        $.get('/Notifications/GetUnreadCount', function(data) {
            if (data && data.count > 0) {
                $('#notification-badge').text(data.count).show();
            }
        });
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
