@using Microsoft.AspNetCore.Identity
@inject UserManager<LeavePro.Models.ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LeavePro Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard-theme.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="dashboard-body employee-theme">

<!-- SIDEBAR OVERLAY -->
<div class="ds-sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

<!-- SIDEBAR -->
<aside class="ds-sidebar" id="mainSidebar">
    <div class="ds-sidebar-logo">
        <div class="ds-logo-icon">LP</div>
        <div class="ds-logo-text">
            <div class="brand-name">LeavePro Portal</div>
        </div>
    </div>

    <nav class="ds-sidebar-nav">
        <a class="ds-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")" 
           asp-controller="Employee" asp-action="Dashboard" title="Dashboard">
            <i class="bi bi-grid-fill"></i>
            <span>Dashboard</span>
        </a>
        <a class="ds-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Apply" ? "active" : "")" 
           asp-controller="Employee" asp-action="Apply" title="Apply Leave">
            <i class="bi bi-plus-circle-fill"></i>
            <span>Apply Leave</span>
        </a>
        <a class="ds-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "History" ? "active" : "")" 
           asp-controller="Employee" asp-action="History" title="Leave History">
            <i class="bi bi-clock-history"></i>
            <span>Leave History</span>
        </a>
        <a class="ds-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Balance" ? "active" : "")" 
           asp-controller="Employee" asp-action="Balance" title="Leave Balance">
            <i class="bi bi-wallet2"></i>
            <span>Leave Balance</span>
        </a>
        <a class="ds-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Holidays" ? "active" : "")" 
           asp-controller="Employee" asp-action="Holidays" title="Holidays">
            <i class="bi bi-calendar-event"></i>
            <span>Holidays</span>
        </a>
        <a class="ds-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "LeavePolicies" ? "active" : "")" 
           asp-controller="Employee" asp-action="LeavePolicies" title="Leave Policies">
            <i class="bi bi-file-earmark-text"></i>
            <span>Leave Policies</span>
        </a>
    </nav>

    <div class="ds-sidebar-footer">
        <a class="ds-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Profile" ? "active" : "")" 
           asp-controller="Employee" asp-action="Profile" title="Profile">
            <i class="bi bi-person-circle"></i>
            <span>Profile</span>
        </a>
        <form class="w-100" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="ds-nav-link border-0 bg-transparent w-100" title="Logout">
                <i class="bi bi-box-arrow-right"></i>
                <span>Logout</span>
            </button>
        </form>
    </div>
</aside>

<!-- TOPBAR -->
<div class="ds-topbar">
    <div class="d-flex align-items-center w-100 gap-3">
        <button class="btn btn-link p-0 text-dark fs-4" onclick="toggleSidebar()" title="Toggle Menu">
            <i class="bi bi-list"></i>
        </button>

        <div class="ms-auto d-flex align-items-center gap-3">
            <div class="text-muted small fw-semibold d-none d-md-flex align-items-center">
                <i class="bi bi-calendar3 me-2"></i> @DateTime.Now.ToString("dd MMM yyyy")
            </div>

            <a asp-controller="Notifications" asp-action="Index" class="position-relative text-dark text-decoration-none mx-2" title="Notifications">
                <i class="bi bi-bell-fill fs-5"></i>
                <span id="notification-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65em; display: none;">0</span>
            </a>

            <div class="ds-profile-trigger">
                <div class="text-end d-none d-sm-block">
                    @{ var empU = await UserManager.GetUserAsync(User); }
                    <div class="ds-profile-name">@(empU != null ? $"{empU.FirstName} {empU.LastName}" : User.Identity?.Name)</div>
                    <div class="ds-profile-role">Employee</div>
                </div>
                <div class="ds-avatar shadow-sm border ms-2" style="background: linear-gradient(135deg, #4f46e5, #312e81); color: #fff;">
                    <i class="bi bi-person-fill fs-5"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- MAIN CONTENT -->
<main class="ds-main">
    <div class="container-fluid p-0">
        @RenderBody()
    </div>
</main>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    $(document).ready(function() {
        $.get('/Notifications/GetUnreadCount', function(data) {
            if (data && data.count > 0) {
                $('#notification-badge').text(data.count).show();
            }
        });
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
