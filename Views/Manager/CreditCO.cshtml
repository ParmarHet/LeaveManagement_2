@model dynamic
@{
    ViewData["Title"] = "Credit Compensatory Off";
    Layout = "_ManagerLayout";
    var teamMembers = ViewBag.TeamMembers as List<LeavePro.Models.ApplicationUser>;
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="content-card shadow-lg p-5" style="border-radius: 24px;">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="bg-primary-subtle text-primary rounded-circle p-3" style="width: 60px; height: 60px; display: flex; align-items:center; justify-content:center;">
                    <i class="fa-solid fa-gift fs-3"></i>
                </div>
                <div>
                    <h3 class="fw-bold mb-0">Credit Compensatory Off</h3>
                    <p class="text-muted mb-0">Reward your team members with extra leave credits for their hard work.</p>
                </div>
            </div>
            
            <form asp-action="CreditCO" method="post" id="creditCOForm">
                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-end mb-3">
                        <label class="form-label fw-bold h6 mb-0">1. Select Team Member(s)</label>
                        <div class="d-flex gap-2">
                            <input type="text" id="memberSearch" class="form-control form-control-sm rounded-pill px-3" placeholder="Search member..." style="width: 180px;">
                            <button type="button" class="btn btn-outline-primary btn-sm rounded-pill px-3" onclick="selectAllMembers()">Select All</button>
                        </div>
                    </div>
                    
                    <div class="row g-3" style="max-height: 400px; overflow-y: auto; padding: 5px;" id="membersGrid">
                        @if (teamMembers != null && teamMembers.Any())
                        {
                            foreach(var member in teamMembers)
                            {
                                var initials = $"{member.FirstName[0]}{member.LastName[0]}".ToUpper();
                                <div class="col-md-4 member-col">
                                    <div class="card h-100 border member-card" onclick="toggleSelection('@member.Id')">
                                        <div class="card-body p-3 d-flex align-items-center gap-3">
                                            <input class="form-check-input visually-hidden" type="checkbox" name="employeeIds" value="@member.Id" id="chk_@member.Id">
                                            <div class="avatar-circle-co">@initials</div>
                                            <div class="overflow-hidden">
                                                <div class="fw-bold small text-truncate m-name">@member.FirstName @member.LastName</div>
                                                <div class="text-muted" style="font-size: 0.65rem;">@member.EmployeeCode</div>
                                            </div>
                                            <i class="fa-solid fa-circle-check ms-auto check-icon text-primary d-none"></i>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
                
                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold h6">2. Date Worked</label>
                        <input type="date" name="dateWorked" class="form-control form-control-lg rounded-3" max="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                        <div class="form-text small">Holiday or weekend date the employee worked.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold h6">3. Reason</label>
                        <input type="text" name="reason" class="form-control form-control-lg rounded-3" required placeholder="e.g. Server Migration Support" />
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 mt-5 pt-3 border-top">
                    <a asp-action="MyTeam" class="btn btn-light rounded-pill px-4 fw-bold border">Cancel</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow">
                        Grant Credit <i class="fa-solid fa-paper-plane ms-2"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .member-card { cursor: pointer; transition: all 0.2s; border-radius: 12px; }
    .member-card:hover { border-color: var(--ds-accent); background: #f8fafc; }
    .member-card.selected { border-width: 2px; border-color: #2563eb; background: #eff6ff; }
    .member-card.selected .check-icon { display: block !important; }
    .avatar-circle-co {
        width: 38px; height: 38px; background: #e0e7ff; color: #4338ca; border-radius: 50%;
        display: flex; align-items:center; justify-content:center; font-weight: 700; font-size: 13px;
        flex-shrink: 0;
    }
    .member-card.selected .avatar-circle-co { background: #2563eb; color: white; }
</style>

<script>
    function toggleSelection(id) {
        const chk = document.getElementById('chk_' + id);
        chk.checked = !chk.checked;
        const card = chk.closest('.member-card');
        if(chk.checked) card.classList.add('selected');
        else card.classList.remove('selected');
    }

    function selectAllMembers() {
        const grid = document.getElementById('membersGrid');
        const cards = grid.querySelectorAll('.member-card');
        const anyUnselected = Array.from(cards).some(c => !c.classList.contains('selected'));
        
        cards.forEach(card => {
            const chk = card.querySelector('input[type="checkbox"]');
            chk.checked = anyUnselected;
            if(anyUnselected) card.classList.add('selected');
            else card.classList.remove('selected');
        });
    }

    document.getElementById('memberSearch').addEventListener('input', function(e) {
        const term = e.target.value.toLowerCase();
        document.querySelectorAll('.member-col').forEach(col => {
            const name = col.querySelector('.m-name').textContent.toLowerCase();
            col.style.display = name.includes(term) ? '' : 'none';
        });
    });
</script>
