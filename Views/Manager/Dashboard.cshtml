@model LMS.Models.ManagerDashboardViewModel
@{
    ViewData["Title"] = "Manager Dashboard";
    Layout = "_ManagerLayout";
}

<div class="ds-page-header align-items-center">
    <h1 class="ds-page-title">Team Management<br>Dashboard</h1>
    
    <div class="d-flex gap-4">
        <!-- Team Pending Card -->
        <div class="ds-stat-card ds-card-amber">
            <div class="ds-stat-label">Pending Approvals</div>
            <div class="ds-stat-value">@Model.PendingRequests</div>
            <div class="ds-stat-icon-floating"><i class="bi bi-check-square-fill"></i></div>
        </div>

        <!-- Team On Leave Card -->
        <div class="ds-stat-card ds-card-green">
            <div class="ds-stat-label">On Leave Today</div>
            <div class="ds-stat-value">@Model.TeamMembersOnLeaveToday</div>
            <div class="ds-stat-icon-floating"><i class="bi bi-person-x-fill"></i></div>
        </div>

        <!-- Total Team Card -->
        <div class="ds-stat-card ds-card-gray">
            <div class="ds-stat-label">Total Team Members</div>
            <div class="ds-stat-value">@Model.TotalTeamMembers</div>
            <div class="ds-stat-icon-floating"><i class="bi bi-people-fill"></i></div>
        </div>
    </div>
</div>

<div class="ds-filter-bar mt-2">
    <div class="ds-filter-pill">Filter by Team Member <i class="bi bi-chevron-down ms-1"></i></div>
    <div class="ds-filter-pill">Select Month <i class="bi bi-chevron-down ms-1"></i></div>
    
    <div class="ms-auto d-flex gap-2">
        <a asp-action="PendingRequests" class="ds-btn-primary">
            Review All Pending
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="ds-table-container mt-0">
            <div class="px-3 py-2 border-bottom d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0">Pending Leave Approvals</h6>
                <a asp-action="PendingRequests" class="small text-decoration-none">Review All</a>
            </div>
            @if (!Model.PendingLeaveRequests.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-check-circle-fill fs-1 d-block mb-2 opacity-10" style="color: #10b981;"></i>
                    <p class="small mb-0">All clear! No pending team requests.</p>
                </div>
            }
            else
            {
                <table class="ds-table">
                    <thead>
                        <tr>
                            <th>Personnel</th>
                            <th>Dates</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var r in Model.PendingLeaveRequests)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="ds-avatar-initials" style="background:#eff6ff; color:#2563eb;">@r.RequestingEmployee?.FirstName?[0]@r.RequestingEmployee?.LastName?[0]</div>
                                    <div class="fw-bold text-dark">@r.RequestingEmployee?.FirstName @r.RequestingEmployee?.LastName</div>
                                </div>
                            </td>
                            <td><span class="text-muted small">@r.StartDate.ToString("dd MMM") – @r.EndDate.ToString("dd MMM")</span></td>
                            <td class="text-end">
                                <a asp-action="Review" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary fw-bold" style="border-radius: 50px;">Review</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </div>
    </div>
    <div class="col-lg-5">
        <div class="ds-table-container mt-0 p-4 mb-4">
            <h6 class="fw-bold mb-4">On Leave Today</h6>
            @if (!Model.TeamOnLeaveToday.Any())
            {
                <p class="text-muted small text-center py-3">No team members on leave today.</p>
            }
            else
            {
                @foreach (var emp in Model.TeamOnLeaveToday)
                {
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="ds-avatar-initials ds-dot-cancel">@emp.FirstName?.Substring(0,1)</div>
                        <span class="fw-semibold text-dark">@emp.FirstName @emp.LastName</span>
                    </div>
                }
            }
        </div>
        
        <div class="ds-table-container mt-0 p-4">
            <h6 class="fw-bold mb-4">Upcoming Team Leaves</h6>
            @if (!Model.UpcomingLeaves.Any())
            {
                <p class="text-muted small text-center py-3">No upcoming leaves in the next 2 weeks.</p>
            }
            else
            {
                @foreach (var u in Model.UpcomingLeaves)
                {
                    <div class="d-flex justify-content-between border-bottom py-3">
                        <div class="fw-bold">@u.RequestingEmployee?.FirstName @u.RequestingEmployee?.LastName</div>
                        <div class="small badge bg-light text-muted fw-bold p-2" style="border-radius: 8px;">@u.StartDate.ToString("dd MMM")</div>
                    </div>
                }
            }
        </div>
    </div>
</div>
