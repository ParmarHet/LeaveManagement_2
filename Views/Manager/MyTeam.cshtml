@model IEnumerable<LeavePro.Models.TeamMemberBalanceViewModel>
@{
    ViewData["Title"] = "Team Portal";
    Layout = "_ManagerLayout";
}

<div class="ds-page-header align-items-center mb-4">
    <div class="d-flex align-items-center gap-3">
        <div class="bg-primary text-white rounded-3 p-2" style="width: 40px; height: 40px; display: flex; align-items:center; justify-content:center;">
             <i class="fa-solid fa-users-viewfinder"></i>
        </div>
        <div>
            <h1 class="ds-page-title mb-0">Team Portal</h1>
            <p class="text-muted small mb-0">Monitor your team's current availability and leave status.</p>
        </div>
    </div>
    <div class="ms-auto">
        <a asp-action="CreditCO" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">
            <i class="fa-solid fa-gift me-2"></i> Credit CO
        </a>
    </div>
</div>

<div class="row g-4">
    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="text-center py-5 text-muted bg-white rounded-4 shadow-sm border border-dashed">
                <i class="fa-solid fa-users-slash fa-3x mb-3 opacity-25"></i>
                <h5 class="fw-bold">No Team Members Linked</h5>
                <p class="small mb-0">Contact HR if this is incorrect.</p>
            </div>
        </div>
    }
    @foreach (var m in Model)
    {
        var initials = $"{m.EmployeeName.Split(' ')[0][0]}{(m.EmployeeName.Split(' ').Length > 1 ? m.EmployeeName.Split(' ')[1][0] : "")}".ToUpper();
        <div class="col-md-6 col-xl-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 team-block" data-bs-toggle="modal" data-bs-target="#modal_@m.EmployeeId">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="avatar-block">@initials</div>
                        <div class="overflow-hidden">
                            <h6 class="fw-bold text-dark text-truncate mb-0">@m.EmployeeName</h6>
                            <div class="text-muted small text-truncate">@m.Email</div>
                        </div>
                    </div>
                    
                    <div class="p-3 bg-light rounded-4 mb-3 d-flex justify-content-around text-center">
                        <div>
                            <div class="text-muted" style="font-size: 10px; font-weight: 700;">CL</div>
                            <div class="fw-bold text-primary">@(m.Balances.FirstOrDefault(b => b.LeaveTypeCode == "CL")?.Remaining ?? 0)</div>
                        </div>
                        <div class="vr opacity-10"></div>
                        <div>
                            <div class="text-muted" style="font-size: 10px; font-weight: 700;">PL</div>
                            <div class="fw-bold text-primary">@(m.Balances.FirstOrDefault(b => b.LeaveTypeCode == "PL")?.Remaining ?? 0)</div>
                        </div>
                        <div class="vr opacity-10"></div>
                        <div>
                            <div class="text-muted" style="font-size: 10px; font-weight: 700;">SL</div>
                            <div class="fw-bold text-primary">@(m.Balances.FirstOrDefault(b => b.LeaveTypeCode == "SL")?.Remaining ?? 0)</div>
                        </div>
                    </div>
                    
                    <div class="text-end">
                        <span class="text-primary small fw-bold">View Profile <i class="fa-solid fa-arrow-right ms-1"></i></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal -->
        <div class="modal fade" id="modal_@m.EmployeeId" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
                    <div class="modal-header border-0 bg-primary-subtle py-4 px-4">
                       <div class="d-flex align-items-center gap-3">
                           <div class="avatar-block bg-primary text-white">@initials</div>
                           <div>
                               <h5 class="modal-title fw-bold mb-0">@m.EmployeeName</h5>
                               <p class="text-muted small mb-0">@m.Shift Shift</p>
                           </div>
                       </div>
                       <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4">
                        <h6 class="fw-bold mb-3 d-flex align-items-center text-dark"><i class="fa-solid fa-chart-pie me-2 text-primary"></i> Leave Balance Overview</h6>
                        <div class="row g-3">
                            @{
                                // User requested to hide ML, BL, and Holiday
                                var filteredBalances = m.Balances.Where(b => 
                                    !b.LeaveTypeCode.Equals("ML", StringComparison.OrdinalIgnoreCase) &&
                                    !b.LeaveTypeCode.Equals("BL", StringComparison.OrdinalIgnoreCase) &&
                                    !b.LeaveTypeName.Contains("Maternity", StringComparison.OrdinalIgnoreCase) &&
                                    !b.LeaveTypeName.Contains("Bereavement", StringComparison.OrdinalIgnoreCase) &&
                                    !b.LeaveTypeName.Contains("Holiday", StringComparison.OrdinalIgnoreCase)
                                ).ToList();
                            }
                            @foreach (var b in filteredBalances)
                            {
                                <div class="col-md-4">
                                    <div class="p-3 border rounded-4 bg-white shadow-sm h-100">
                                        <div class="small fw-bold text-muted text-uppercase mb-1" style="font-size: 10px;">@b.LeaveTypeName</div>
                                        <div class="h4 mb-0 fw-bold text-primary">@b.Remaining <small class="text-muted fw-normal" style="font-size: 11px;">/@b.Allocated</small></div>
                                    </div>
                                </div>
                            }
                        </div>
                        
                        <h6 class="fw-bold mt-4 mb-3 d-flex align-items-center text-dark"><i class="fa-solid fa-clock-rotate-left me-2 text-primary"></i> Recent Requests</h6>
                        <div class="list-group list-group-flush border rounded-4 overflow-hidden">
                            @if(!m.History.Any())
                            {
                                <div class="list-group-item text-center py-3 text-muted small">No history available.</div>
                            }
                            @foreach(var h in m.History.Take(5))
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center p-3">
                                    <div>
                                        <div class="fw-bold small">@h.LeaveType?.Name</div>
                                        <div class="text-muted" style="font-size: 0.7rem;">@h.StartDate.ToString("dd MMM") - @h.EndDate.ToString("dd MMM yyyy")</div>
                                    </div>
                                    <span class="badge @(h.Approved == true ? "bg-success-subtle text-success" : (h.Approved == false ? "bg-danger-subtle text-danger" : "bg-warning-subtle text-warning")) rounded-pill small px-3">
                                        @(h.Approved == true ? "Approved" : (h.Approved == false ? "Rejected" : "Pending"))
                                    </span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .avatar-block {
        width: 48px; height: 48px; background: #eff6ff; color: #2563eb; border-radius: 14px;
        display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 16px;
    }
    .team-block { cursor: pointer; transition: all 0.25s ease; }
    .team-block:hover { 
        transform: translateY(-5px); 
        box-shadow: 0 15px 30px rgba(0,0,0,0.08) !important;
        background: #fdfdff;
    }
</style>
