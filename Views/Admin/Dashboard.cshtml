@model LMS.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "Executive Overview";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="ds-page-header">
    <h1 class="ds-page-title">Executive<br>Overview</h1>
    
    <div class="d-flex gap-4">
        <!-- Success/Total Card -->
        <div class="ds-stat-card ds-card-green" style="background-color: #e0f2fe; color: #0284c7;">
            <div class="ds-stat-label" style="color: #0284c7;">Total Employees</div>
            <div class="ds-stat-value" style="color: #0369a1;">@Model.TotalEmployees</div>
            <div class="ds-stat-icon-floating"><i class="bi bi-people-fill"></i></div>
        </div>

        <!-- Info/Active Card -->
        <div class="ds-stat-card ds-card-gray" style="background-color: #fce7f3; color: #db2777;">
            <div class="ds-stat-label" style="color: #db2777;">Active Managers</div>
            <div class="ds-stat-value" style="color: #be185d;">@Model.TotalManagers</div>
            <div class="ds-stat-icon-floating"><i class="bi bi-person-badge-fill"></i></div>
        </div>

        <!-- Warning/Pending Card -->
        <div class="ds-stat-card ds-card-amber" style="background-color: #fef9c3; color: #ca8a04;">
            <div class="ds-stat-label" style="color: #ca8a04;">Pending Action</div>
            <div class="ds-stat-value" style="color: #a16207;">@Model.PendingApprovals</div>
            <div class="ds-stat-icon-floating"><i class="bi bi-hourglass-split"></i></div>
        </div>
    </div>
</div>

<div class="ds-filter-bar d-flex gap-2 align-items-center mb-3 p-3 bg-white shadow-sm" style="border-radius: 12px;">
    <select id="filterDepartment" class="form-select w-auto rounded-pill border-light text-muted small" onchange="filterDashboardTable()">
        <option value="All">All Departments</option>
        @if (ViewBag.Departments != null)
        {
            @foreach(var dept in (List<LMS.Models.Department>)ViewBag.Departments)
            {
                <option value="@dept.Name">@dept.Name</option>
            }
        }
    </select>
    
    <div class="ms-auto d-flex gap-2">
        <a asp-controller="Users" asp-action="Index" class="ds-btn-primary">
            Manage Personnel
        </a>
    </div>
</div>

<div class="ds-table-container">
    <table class="ds-table">
        <thead>
            <tr>
                <th style="width: 250px;">Employee</th>
                <th>Leave Type</th>
                <th>Department</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.EmployeesOnLeaveTodayList.Any())
            {
                @foreach (var leave in Model.EmployeesOnLeaveTodayList)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div class="ds-avatar-initials">@leave.RequestingEmployee?.FirstName?[0]@leave.RequestingEmployee?.LastName?[0]</div>
                                <div class="fw-bold text-dark">@leave.RequestingEmployee?.FirstName @leave.RequestingEmployee?.LastName</div>
                            </div>
                        </td>
                        <td><span class="text-secondary">@leave.LeaveType?.Name</span></td>
                        <td><span class="badge bg-light text-dark border">@leave.RequestingEmployee?.Department?.Name</span></td>
                        <td>
                            <div class="ds-status-dot ds-dot-success">Active</div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center py-5">
                        <div class="text-muted small">No absences reported today. 100% Operational.</div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
    function filterDashboardTable() {
        const deptFilter = document.getElementById('filterDepartment').value.toLowerCase();
        const rows = document.querySelectorAll('.ds-table tbody tr');

        rows.forEach(row => {
            if (row.cells.length < 4) return; 
            const dept = row.cells[2].textContent.toLowerCase();

            const matchesDept = deptFilter === 'all' || dept.includes(deptFilter);

            if (matchesDept) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }
</script>
