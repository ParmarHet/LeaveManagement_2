@model LeavePro.Models.ApplicationUser
@{
    ViewData["Title"] = "Admin Profile";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var initials = (Model.FirstName?[..1] ?? "A") + (Model.LastName?[..1] ?? "");
}

<div class="ds-page-header align-items-center mb-4">
    <h1 class="ds-page-title">Account Profile</h1>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card shadow-sm rounded-4 p-4 text-center">
            <div class="profile-avatar mb-3 mx-auto" style="width:96px;height:96px;border-radius:24px;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#2563eb,#4f46e5);color:#fff;font-size:28px;font-weight:800;">@initials</div>
            <h5 class="mb-0">@Model.FirstName @Model.LastName</h5>
            <p class="text-muted small mb-2">System Administrator</p>
            <div class="d-flex justify-content-center gap-2 mb-3">
                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2">Active Session</span>
            </div>
        </div>

        <div class="card shadow-sm rounded-4 p-3 mt-3">
            <h6 class="fw-bold mb-2">Privileges</h6>
            <ul class="list-unstyled mb-0">
                <li class="mb-2"><i class="bi bi-check-circle-fill text-primary me-2"></i>Full Access</li>
                <li class="mb-2"><i class="bi bi-database-fill text-success me-2"></i>Database Management</li>
                <li><i class="bi bi-bell-fill text-info me-2"></i>Broadcast Alerts</li>
            </ul>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm rounded-4 p-4 mb-4">
            <h6 class="fw-bold mb-3">Account Details</h6>
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="text-muted small">First Name</div>
                    <div class="fw-semibold">@Model.FirstName</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">Last Name</div>
                    <div class="fw-semibold">@Model.LastName</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">Email</div>
                    <div class="fw-semibold">@Model.Email</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">Admin ID</div>
                    <div class="fw-semibold">@Model.Id.Substring(0,8).ToUpper()</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">Joined</div>
                    <div class="fw-semibold">@Model.DateJoined.ToString("dd MMM yyyy")</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">Status</div>
                    <div class="fw-semibold">@Model.Status</div>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-primary">Edit Account</a>
                <a asp-action="ChangePassword" class="btn btn-outline-secondary">Change Password</a>
            </div>
        </div>

        <div class="alert alert-info border-0 shadow-sm rounded-4 d-flex align-items-center p-4">
            <i class="bi bi-info-circle-fill fs-3 me-3"></i>
            <div>
                <h6 class="fw-bold mb-1">Administrative Role Security</h6>
                <p class="mb-0 small">Your account has administrative privileges. Actions are audited and protected with enterprise policies.</p>
            </div>
        </div>
    </div>
</div>

<style>
    .profile-avatar { width:96px;height:96px;border-radius:24px; }
    .rounded-4 { border-radius: 1.25rem !important; }
</style>
