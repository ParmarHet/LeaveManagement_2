@model LMS.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Account Settings";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var user = ViewBag.User as LMS.Models.ApplicationUser;
    var initials = (user?.FirstName?[..1] ?? "A") + (user?.LastName?[..1] ?? "");
}

<div class="settings-container animate-fade-in">
    <!-- Header -->
    <div class="ds-page-header d-flex align-items-center justify-content-between mb-5">
        <div>
            <h1 class="ds-page-title mb-1">Account Settings</h1>
            <p class="text-muted small mb-0">Manage your profile information and account security</p>
        </div>
        <div class="d-none d-md-block">
            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-10 px-3 py-2 rounded-pill">
                <i class="bi bi-shield-check me-1"></i> Global Admin
            </span>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4 mb-4 d-flex align-items-center">
            <i class="bi bi-check-circle-fill fs-4 me-3"></i>
            <div>@TempData["Success"]</div>
        </div>
    }

    <div class="row g-4">
        <!-- Sidebar / Profile Info -->
        <div class="col-xl-4 col-lg-5">
            <!-- Information Profile Type Card -->
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                <div class="card-body p-4 text-center">
                    <div class="profile-avatar mb-4 mx-auto" style="width:100px; height:100px;">
                        <div class="avatar-circle">@initials</div>
                    </div>
                    <h4 class="fw-bold mb-1">@user?.FirstName @user?.LastName</h4>
                    <p class="text-muted small mb-4">@user?.Email</p>
                    
                    <div class="info-grid text-start">
                        <div class="info-item mb-3">
                            <label class="text-muted d-block small fw-bold text-uppercase">Employee ID</label>
                            <span class="fw-semibold">@user?.EmployeeCode</span>
                        </div>
                        <div class="info-item mb-3">
                            <label class="text-muted d-block small fw-bold text-uppercase">Role</label>
                            <span class="badge bg-soft-info text-info">System Administrator</span>
                        </div>
                        <div class="info-item mb-3">
                            <label class="text-muted d-block small fw-bold text-uppercase">Joining Date</label>
                            <span class="fw-semibold">@user?.DateJoined.ToString("dd MMMM yyyy")</span>
                        </div>
                        <div class="info-item">
                            <label class="text-muted d-block small fw-bold text-uppercase">Department</label>
                            <span class="fw-semibold">@(user?.Department?.Name ?? "Admin HQ")</span>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light border-0 p-3 text-center">
                    <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-link link-primary text-decoration-none small fw-bold">
                        Edit Identity Details <i class="bi bi-chevron-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Main Content / Security -->
        <div class="col-xl-8 col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4 p-md-5">
                    <h5 class="fw-bold mb-4 d-flex align-items-center">
                        <i class="bi bi-shield-lock me-2 text-primary"></i> Password Management
                    </h5>
                    
                    <form asp-action="Settings" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small rounded-3 mb-4" role="alert"></div>

                        <div class="row g-3">
                            <div class="col-12">
                                <div class="form-floating mb-3">
                                    <input asp-for="OldPassword" class="form-control" placeholder="Current Password" />
                                    <label asp-for="OldPassword">Current Password</label>
                                    <span asp-validation-for="OldPassword" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input asp-for="NewPassword" class="form-control" placeholder="New Password" />
                                    <label asp-for="NewPassword">New Password</label>
                                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm New Password" />
                                    <label asp-for="ConfirmPassword">Confirm New Password</label>
                                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between mt-4 gap-3">
                            <button type="submit" class="btn btn-primary px-4 py-2 rounded-pill fw-bold">
                                <i class="bi bi-arrow-repeat me-2"></i>Update Password
                            </button>
                            
                            <!-- Forgot Password Section -->
                            <div class="forgot-password-trigger">
                                <span class="text-muted small me-2">Forgotten your password?</span>
                                <a asp-area="Identity" asp-page="/Account/ForgotPassword" class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold">
                                    <i class="bi bi-envelope-exclamation me-1"></i> Reset via Email
                                </a>
                            </div>
                        </div>
                    </form>

                    <hr class="my-5 opacity-50">

                    <!-- Two Factor / Account Security Info -->
                    <div class="security-info-box p-4 rounded-4 bg-soft-warning">
                        <div class="d-flex">
                            <i class="bi bi-exclamation-triangle-fill text-warning fs-3 me-3"></i>
                            <div>
                                <h6 class="fw-bold mb-1">Account Recovery</h6>
                                <p class="text-muted small mb-0">
                                    If you lose access to your password, you can use the "Reset via Email" tool. 
                                    Ensure your registered email (@user?.Email) is correct and accessible.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #2563eb, #4f46e5);
    }
    .settings-container { max-width: 1200px; margin: 0 auto; }
    .card { transition: all 0.3s ease; }
    .rounded-4 { border-radius: 1rem !important; }
    
    .avatar-circle {
        width: 100px; height: 100px;
        background: var(--primary-gradient);
        color: white;
        border-radius: 30px;
        display: flex; align-items: center; justify-content: center;
        font-size: 32px; font-weight: 800;
        box-shadow: 0 10px 20px rgba(79, 70, 229, 0.2);
    }

    .info-grid { padding: 10px; }
    .bg-soft-info { background-color: rgba(13, 202, 240, 0.1); }
    .bg-soft-success { background-color: rgba(25, 135, 84, 0.1); }
    .bg-soft-warning { background-color: rgba(255, 193, 7, 0.1); }
    .text-warning { color: #f59e0b !important; }

    .nav-tabs .nav-link { 
        color: #6c757d; 
        transition: all 0.2s ease;
        border-bottom: 2px solid transparent !important;
    }
    .nav-tabs .nav-link.active { 
        color: #4f46e5 !important; 
        background: transparent !important;
        border-bottom-color: #4f46e5 !important;
    }
    
    .activity-icon {
        width: 42px; height: 42px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px;
    }

    .extra-small { font-size: 11px; }
    
    .form-control { border-radius: 12px; padding: 1.25rem 1rem; border: 1px solid #e2e8f0; }
    .form-control:focus { box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1); border-color: #4f46e5; }
    
    .animate-fade-in { animation: fadeIn 0.5s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>
