@model LMS.Models.AdminLeaveHistoryViewModel
@{
    ViewData["Title"] = "Leave History & Stats";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2><i class="bi bi-clock-history me-2" style="color:#6366f1"></i>Leave History & Statistics</h2>
            <p>Comprehensive overview of company-wide attendance and leave status</p>
        </div>
        <div class="text-end">
            <span class="badge bg-primary px-3 py-2">Total Employees: @Model.TotalEmployees</span>
        </div>
    </div>
</div>

<!-- TOP STATS -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="stat-card shadow-sm border-0 d-flex align-items-center p-4" style="background: linear-gradient(135deg, #fff5f5 0%, #fff 100%); border-radius: 20px;">
            <div class="stat-icon me-4 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px; background: #ffe3e3; border-radius: 20px; box-shadow: 0 10px 20px rgba(225, 29, 72, 0.1);">
                <i class="bi bi-person-x-fill" style="color: #e11d48; font-size: 2rem;"></i>
            </div>
            <div>
                <div class="stat-value fw-bold text-dark" style="font-size: 2rem; line-height: 1;">@Model.OnLeaveTodayCount</div>
                <div class="stat-label text-muted small text-uppercase ls-wide fw-bold">On Leave Today</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card shadow-sm border-0 d-flex align-items-center p-4" style="background: linear-gradient(135deg, #fffbeb 0%, #fff 100%); border-radius: 20px;">
            <div class="stat-icon me-4 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px; background: #fef3c7; border-radius: 20px; box-shadow: 0 10px 20px rgba(217, 119, 6, 0.1);">
                <i class="bi bi-hourglass-split" style="color: #d97706; font-size: 2rem;"></i>
            </div>
            <div>
                <div class="stat-value fw-bold text-dark" style="font-size: 2rem; line-height: 1;">@Model.PendingApprovalsCount</div>
                <div class="stat-label text-muted small text-uppercase ls-wide fw-bold">Pending Approvals</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card shadow-sm border-0 d-flex align-items-center p-4" style="background: linear-gradient(135deg, #eff6ff 0%, #fff 100%); border-radius: 20px;">
            <div class="stat-icon me-4 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px; background: #dbeafe; border-radius: 20px; box-shadow: 0 10px 20px rgba(37, 99, 235, 0.1);">
                <i class="bi bi-people-fill" style="color: #2563eb; font-size: 2rem;"></i>
            </div>
            <div>
                <div class="stat-value fw-bold text-dark" style="font-size: 2rem; line-height: 1;">@Model.TotalAbsent</div>
                <div class="stat-label text-muted small text-uppercase ls-wide fw-bold">Total Absent Today</div>
            </div>
        </div>
    </div>
</div>

<ul class="nav nav-pills mb-4" id="historyTab" role="tablist">
    <li class="nav-item">
        <button class="nav-link active" id="today-tab" data-bs-toggle="pill" data-bs-target="#today" type="button">Today's Leaves</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" id="pending-tab" data-bs-toggle="pill" data-bs-target="#pending" type="button">Pending Approvals</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" id="dept-tab" data-bs-toggle="pill" data-bs-target="#dept" type="button">Department Wise Details</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" id="all-tab" data-bs-toggle="pill" data-bs-target="#all" type="button">All Leaves History</button>
    </li>
</ul>

<div class="tab-content" id="historyTabContent">
    <!-- Today's Leaves -->
    <div class="tab-pane fade show active" id="today" role="tabpanel">
        <div class="admin-table">
            <table class="table">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Leave Type</th>
                        <th>Period</th>
                        <th>Duration</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model.TodayLeaves.Any()) {
                        @foreach (var leave in Model.TodayLeaves) {
                            <tr>
                                <td>
                                    <div class="fw-bold">@leave.EmployeeName</div>
                                    <div class="text-muted smaller">@leave.EmployeeEmail</div>
                                </td>
                                <td><span class="badge bg-primary bg-opacity-10 text-primary">@leave.LeaveTypeName</span></td>
                                <td>@leave.StartDate.ToString("dd MMM") - @leave.EndDate.ToString("dd MMM yyyy")</td>
                                <td>@leave.TotalDays Days</td>
                                <td><span class="badge bg-success">Active</span></td>
                            </tr>
                        }
                    } else {
                        <tr><td colspan="5" class="text-center py-4">No employees on leave today.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pending Approvals -->
    <div class="tab-pane fade" id="pending" role="tabpanel">
        <div class="admin-table">
            <table class="table">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Leave Type</th>
                        <th>Requested On</th>
                        <th>Period</th>
                        <th>Days</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model.PendingLeaves.Any()) {
                        @foreach (var leave in Model.PendingLeaves) {
                            <tr style="transition: background-color 0.2s;" onmouseover="this.style.backgroundColor='#f8fafc';" onmouseout="this.style.backgroundColor='';">
                                <td>
                                    <div class="fw-bold">@leave.EmployeeName</div>
                                    <div class="text-muted smaller">@leave.EmployeeEmail</div>
                                </td>
                                <td><span class="badge" style="background-color: #fef08a; color: #854d0e; border-radius: 12px; padding: 6px 10px;">@leave.LeaveTypeName</span></td>
                                <td>@leave.DateRequested.ToString("dd MMM yyyy")</td>
                                <td>@leave.StartDate.ToString("dd MMM") - @leave.EndDate.ToString("dd MMM yyyy")</td>
                                <td><span class="badge bg-light text-dark border">@leave.TotalDays Days</span></td>
                                <td>
                                    <form asp-action="Approve" asp-controller="Admin" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@leave.Id" />
                                        <button type="submit" class="btn btn-sm" style="background-color: #4ade80; color: white; border-radius: 20px; font-weight: 500;"><i class="bi bi-check-circle me-1"></i> Accept</button>
                                    </form>
                                    <form asp-action="Reject" asp-controller="Admin" method="post" class="d-inline ms-1">
                                        <input type="hidden" name="id" value="@leave.Id" />
                                        <button type="submit" class="btn btn-sm" style="background-color: #f87171; color: white; border-radius: 20px; font-weight: 500;"><i class="bi bi-x-circle me-1"></i> Reject</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    } else {
                        <tr><td colspan="6" class="text-center py-5 text-muted"><i class="bi bi-emoji-smile fs-3 d-block mb-2"></i> All caught up! No pending approvals.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Department Wise Details -->
    <div class="tab-pane fade" id="dept" role="tabpanel">
        <div class="row g-4">
            @foreach (var dept in Model.DepartmentStats) {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
                        <div class="card-header bg-white border-bottom-0 py-3">
                            <h6 class="mb-0 fw-bold"><i class="bi bi-diagram-3 me-2 text-primary"></i>@dept.DepartmentName</h6>
                        </div>
                        <div class="card-body pt-0">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted small">Total Employees</span>
                                <span class="fw-bold">@dept.TotalEmployees</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted small">On Leave Today</span>
                                <span class="badge bg-danger bg-opacity-10 text-danger">@dept.OnLeaveToday</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted small">Pending Approvals</span>
                                <span class="badge bg-info bg-opacity-10 text-info">@dept.PendingApprovals</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- All Leaves History -->
    <div class="tab-pane fade" id="all" role="tabpanel">
        <div class="card border-0 shadow-sm rounded-4 mb-4 p-3 bg-white">
            <form method="get" asp-action="LeaveHistory">
                <div class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label small text-muted fw-bold">Search</label>
                        <input type="text" name="searchName" class="form-control form-control-sm" placeholder="Employee Name" value="@ViewBag.CurrentSearch" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small text-muted fw-bold">Department</label>
                        <select name="departmentId" class="form-select form-select-sm">
                            <option value="">All Departments</option>
                            @if (ViewBag.DepartmentsList != null)
                            {
                                foreach (var d in (IEnumerable<LMS.Models.Department>)ViewBag.DepartmentsList)
                                {
                                    if (ViewBag.CurrentDept != null && ViewBag.CurrentDept == d.Id)
                                    {
                                        <option value="@d.Id" selected>@d.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@d.Id">@d.Name</option>
                                    }
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small text-muted fw-bold">Leave Type</label>
                        <select name="leaveTypeId" class="form-select form-select-sm">
                            <option value="">All Types</option>
                            @if (Model.LeaveTypes != null)
                            {
                                foreach (var t in Model.LeaveTypes)
                                {
                                    if (ViewBag.CurrentLeaveType != null && ViewBag.CurrentLeaveType == t.Id)
                                    {
                                        <option value="@t.Id" selected>@t.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@t.Id">@t.Name</option>
                                    }
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small text-muted fw-bold">Role</label>
                        <select name="role" class="form-select form-select-sm">
                            <option value="">All Roles</option>
                            @foreach (var r in new[] { "Admin", "Manager", "Employee" })
                            {
                                if (ViewBag.CurrentRole != null && ViewBag.CurrentRole == r)
                                {
                                    <option value="@r" selected>@r</option>
                                }
                                else
                                {
                                    <option value="@r">@r</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small text-muted fw-bold">Date</label>
                        <input type="date" name="date" class="form-control form-control-sm" value="@ViewBag.CurrentDate" />
                    </div>
                    <div class="col-md-1 d-flex gap-2">
                        <button type="submit" class="btn btn-sm btn-primary w-100"><i class="bi bi-filter"></i></button>
                        <a asp-action="LeaveHistory" class="btn btn-sm btn-light border"><i class="bi bi-x-lg"></i></a>
                    </div>
                </div>
            </form>
        </div>

        <div class="admin-table">
            <table class="table">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Leave Type</th>
                        <th>Period</th>
                        <th>Days</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model.AllLeaves.Any()) {
                        @foreach (var leave in Model.AllLeaves) {
                            <tr>
                                <td>
                                    <div class="fw-bold">@leave.EmployeeName</div>
                                    <div class="text-muted smaller">@leave.EmployeeEmail</div>
                                </td>
                                <td><span class="badge bg-secondary bg-opacity-10 text-dark">@leave.LeaveTypeName</span></td>
                                <td>@leave.StartDate.ToString("dd MMM yyyy") - @leave.EndDate.ToString("dd MMM yyyy")</td>
                                <td>@leave.TotalDays</td>
                                <td>
                                    @if(leave.Status == "Approved") {
                                        <span class="badge bg-success">Approved</span>
                                    } else if(leave.Status == "Rejected") {
                                        <span class="badge bg-danger">Rejected</span>
                                    } else if(leave.Status == "Cancelled") {
                                        <span class="badge bg-secondary">Cancelled</span>
                                    } else {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                </td>
                            </tr>
                        }
                    } else {
                         <tr><td colspan="5" class="text-center py-4 text-muted">No records found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Leave Structure removed from here; available via Admin -> Leave Structure sidebar link -->
</div>

@section Scripts {
    <style>
        .smaller { font-size: 0.75rem; }
        .nav-pills .nav-link {
            border-radius: 8px;
            color: #64748b;
            font-weight: 500;
            padding: 10px 20px;
        }
        .nav-pills .nav-link.active {
            background-color: #6366f1;
            color: #fff;
        }
    </style>
}
