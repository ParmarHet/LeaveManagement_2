@page
@model LMS.Areas.Identity.Pages.Account.ForgotPasswordModel

@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_AuthLayout";
}

<div class="auth-container">
    <div class="auth-header d-flex flex-column align-items-center">
        <h1 class="mb-1">Forgot Password</h1>
        <p class="text-muted">Enter your account email and we'll send a link to reset your password.</p>
    </div>

    <form method="post" class="mt-3">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2" role="alert"></div>

        <div class="form-floating mb-3">
            <input asp-for="Input.Email" class="form-control" placeholder="name@example.com" autocomplete="email" />
            <label asp-for="Input.Email">Email address</label>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <button type="submit" class="w-100 btn btn-lg btn-primary mb-3">Send reset link</button>

        <div class="text-center small">
            <a asp-page="./Login">Back to Sign in</a> • <a asp-page="./Register">Create account</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
