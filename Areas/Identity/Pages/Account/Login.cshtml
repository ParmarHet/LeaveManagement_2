@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    Layout = "_AuthLayout";
}

<div class="auth-container">
    <div class="auth-header d-flex flex-column align-items-center">
        <h1 class="mb-1">Welcome Back</h1>
        <p class="text-muted">Log in to access your LeavePro portal</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 mb-4 shadow-sm d-flex align-items-center" role="alert" style="border-radius: 12px; font-weight: 500; background-color: #ecfdf5; color: #065f46; font-size: 0.9rem;">
            <i class="bi bi-check-circle-fill me-2 fs-5"></i> 
            <div>@TempData["SuccessMessage"]</div>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger border-0 mb-4 shadow-sm d-flex align-items-center" role="alert" style="border-radius: 12px; font-weight: 500; background-color: #fef2f2; color: #991b1b; font-size: 0.9rem;">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i> 
            <div>@TempData["ErrorMessage"]</div>
        </div>
    }

    <form id="account" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
        <div class="form-floating mb-3">
            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
            <label asp-for="Input.Email">Email Address</label>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>
        <div class="form-floating mb-3">
            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
            <label asp-for="Input.Password">Password</label>
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="form-check">
                <input class="form-check-input" asp-for="Input.RememberMe" id="rememberMe" />
                <label class="form-check-label ms-2" for="rememberMe">Remember me</label>
            </div>
            <a id="forgot-password" asp-page="./ForgotPassword" class="small text-decoration-none">Forgot password?</a>
        </div>
        <div>
            <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary mb-3">Log in</button>
        </div>
    </form>

    @{ if ((Model.ExternalLogins?.Count ?? 0) > 0) {
        <div class="divider">or continue with</div>
        <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div class="d-grid gap-2">
                @foreach (var provider in Model.ExternalLogins!)
                {
                    <button type="submit" class="btn btn-outline-secondary" name="provider" value="@provider.Name">@provider.DisplayName</button>
                }
            </div>
        </form>
    } }

    <div class="auth-footer">
        Don't have an account? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create One</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
