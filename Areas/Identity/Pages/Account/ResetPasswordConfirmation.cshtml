@page
@{
    ViewData["Title"] = "Password Reset";
    Layout = "_AuthLayout";
}

<div class="auth-container text-center">
    <div class="auth-header mb-3">
        <h1 class="mb-1">Password reset</h1>
        <p class="text-muted">Your password has been reset successfully. You can now sign in with your new password.</p>
    </div>

    <div class="mt-2">
        <a asp-page="./Login" class="btn btn-primary px-4">Sign in</a>
    </div>
</div>
