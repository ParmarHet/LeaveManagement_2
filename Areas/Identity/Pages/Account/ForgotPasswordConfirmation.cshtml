@page
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_AuthLayout";
}

<div class="auth-container text-center">
    <div class="auth-header mb-3">
        <h1 class="mb-1">Check your email</h1>
        <p class="text-muted">If an account with that email exists, we have sent instructions to reset your password.</p>
    </div>

    <div class="mt-2">
        <a asp-page="./Login" class="btn btn-primary px-4">Back to Sign in</a>
    </div>
</div>
